# بريد التواصل (اختياري). إذا تُرك فارغًا، يُخفى صندوق البريد في التذييل.
# يُضبط فقط عند توفّر بريد حقيقي للتواصل.
NEXT_PUBLIC_CONTACT_EMAIL=

# Supabase (اختياري). عند ضبط القيمتين يُفعّل التخزين الحقيقي لفزعتك،
# وإلا يبقى التطبيق على التخزين المحلي (localStorage).
# anon key مفتاح عام يُشحن للمتصفح — الأمان يعتمد كليًا على RLS.
# لا تضع service_role key هنا أو في أي كود متصفح/CI عام.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
